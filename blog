---
layout: blog
title: Blog
---

{% for post in site.posts limit:5 %}
<div class="article">

<h3><a href="{{ post.url }}">{{ post.title }}</a></h3>
<p class="post-meta">by {{post.author}} &bull; {{ post.date | date_to_long_string }} &bull; {{post.category}}</p>

<p>{{ post.excerpt }}</p>

<p class="fancy-link"><a href="{{ post.url }}">Continue Reading</a></p>

</div>

{% endfor %}