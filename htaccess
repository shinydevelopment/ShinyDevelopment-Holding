Options +SymLinksIfOwnerMatch +MultiViews
RewriteEngine on
RewriteLog "/var/log/apache2/mod_rewrite.log"
RewriteBase /

# Get rid of www in the domain
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^_site\/(.*)$ http://%1/$1 [R=301]

# Redirect old web pages
Redirect 301 /statusmagic /status-magic
Redirect 301 /interestingness http://exploreflickr.com
Redirect 301 /explore-flickr http://exploreflickr.com
Redirect 301 /speakapedia/updates.xml http://shinydev-updates.s3.amazonaws.com/speakapedia.xml
Redirect 301 /support http://shinydevelopment.com/contact

# Custom error
ErrorDocument 404 /error.html
